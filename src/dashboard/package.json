{
  "name": "dashboard",
  "version": "2.0.0",
  "description": "A local Kubernetes service dashboard.",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "start": "node --import ./server/tracing.js server/server.js",
    "test": "node --test tests/unit/*.test.js",
    "test:smoke": "playwright test tests/smoke.spec.js",
    "test:all": "npm test && npm run test:smoke",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.221.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.221.0",
    "@opentelemetry/resources": "^2.10.0",
    "@opentelemetry/sdk-metrics": "^2.10.0",
    "@opentelemetry/sdk-node": "^0.221.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0"
  }
}
